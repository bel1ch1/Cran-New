# Веб-интерфейс
CRAN_APP_PORT=8000
CRAN_AUTH_USER=admin
CRAN_AUTH_PASSWORD=admin
CRAN_SESSION_SECRET=change-this-in-production

# Камеры (Raspberry Pi + picamera2)
CRAN_CAMERA_BACKEND=picamera2
CRAN_BRIDGE_CAMERA_DEVICE=/dev/video0
CRAN_HOOK_CAMERA_DEVICE=/dev/video1

# Modbus (порт на хосте)
CRAN_MODBUS_PORT=5020
CRAN_MODBUS_PUBLISHED_PORT=5020
CRAN_MODBUS_UNIT_ID=1
CRAN_MODBUS_BRIDGE_BASE_REGISTER=100
CRAN_MODBUS_HOOK_BASE_REGISTER=200

# Pose runtime — docs/methodology/pose-filtering-and-tuning.md
CRAN_POSE_FPS=10
CRAN_POSE_SMOOTH_ALPHA=0.55
CRAN_POSE_MAX_STEP_M=0.022
CRAN_POSE_OUTLIER_M=0.020
CRAN_POSE_WINDOW=5
CRAN_POSE_HOLD_LAST=1
CRAN_POSE_USE_SUBPIX=1
CRAN_POSE_USE_SOLVEPNP=1
CRAN_POSE_SKIP_JPEG=1
CRAN_POSE_DEBUG=0

# Spatial map (калибровка + runtime)
CRAN_MIN_TRUST_HITS=7
CRAN_MAX_TRUST_SIGMA_M=0.05
CRAN_MIN_LANDMARK_SEPARATION_M=0.03
CRAN_MERGE_TOLERANCE_M=0.02
CRAN_RUNTIME_MATCH_TOLERANCE_M=0.04

# InfluxDB (история для /statistics)
CRAN_INFLUX_PUBLISHED_PORT=8086
CRAN_INFLUX_USERNAME=cran
CRAN_INFLUX_PASSWORD=cran-influx-secret
CRAN_INFLUX_ORG=cran
CRAN_INFLUX_BUCKET=cran
CRAN_INFLUX_TOKEN=cran-influx-token-change-me
CRAN_INFLUX_MEASUREMENT=crane_pose
CRAN_INFLUX_WRITE_INTERVAL=1.0
