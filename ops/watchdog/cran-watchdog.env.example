# CRAN hardware watchdog configuration.
# Installed to /etc/cran/watchdog.env by ops/watchdog/install.sh

# How often test-binary runs (seconds). Default: 5 minutes.
CRAN_WATCHDOG_CHECK_INTERVAL_S=300

# Do not fail/reboot during early boot while Docker stack is starting.
# Default: 15 minutes after OS boot.
CRAN_WATCHDOG_BOOT_GRACE_S=900

# If stack never became healthy, keep waiting up to this uptime before failing.
# Default: 30 minutes.
CRAN_WATCHDOG_STARTUP_TIMEOUT_S=1800

# Consecutive failed checks before reboot. With 300s interval => 15 minutes.
CRAN_WATCHDOG_MAX_FAILS=3

# Host path to shared runtime directory (bind-mounted from ./data/runtime).
CRAN_WATCHDOG_DATA_DIR=/home/cran/Cran-New/data/runtime

# Space-separated Docker container names to verify.
CRAN_WATCHDOG_SERVICES="cran_calibration_app cran_bridge_supervisor cran_hook_supervisor cran_influxdb cran_pose_influx_writer"

# Heartbeat freshness thresholds (seconds).
CRAN_WATCHDOG_SUP_HEARTBEAT_MAX_AGE=120
CRAN_WATCHDOG_CHILD_HEARTBEAT_MAX_AGE=120
CRAN_WATCHDOG_INFLUX_WRITER_HEARTBEAT_MAX_AGE=300

CRAN_WATCHDOG_STATE_DIR=/run/cran-watchdog
CRAN_WATCHDOG_LOCK_FILE=/home/cran/Cran-New/data/runtime/calibration.lock
